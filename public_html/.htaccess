# Agro Admin Panel · Apache (InfinityFree)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Bloquear acceso directo a config y SQL
  RewriteRule ^config\.php$ - [F,L]
  RewriteRule ^sql/ - [F,L]

  # API pretty URLs: /api/login -> /api/login.php
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^api/([a-z0-9_]+)/?$ api/$1.php [L,QSA]

  # Carpetas API con acción: /api/carpetas/prestamo -> carpetas.php?action=prestamo
  RewriteRule ^api/carpetas/([a-z]+)/?$ api/carpetas.php?action=$1 [L,QSA]
</IfModule>

# Proteger archivos sensibles
<FilesMatch "^(config\.php|config\.example\.php)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
</FilesMatch>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
</IfModule>
